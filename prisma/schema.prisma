generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(cuid())
  telegramId               String   @unique
  name                     String?
  level                    Int      @default(1)
  xp                       Int      @default(0)
  freeAnalyses             Int      @default(3)
  paidAnalyses             Int      @default(0)
  freeChatQuestions        Int      @default(3)
  referralCount            Int      @default(0)
  streakFreezes            Int      @default(0)
  proTrialUntil            DateTime?
  monthStreakBadge         Boolean  @default(false)
  subscriptionEnd          DateTime?
  lastSubscriptionOfferSent DateTime?
  /// Photo-perceptual hash of the user's most recent analysis. Used for
  /// O(1) duplicate detection before falling back to full hash scan.
  lastPhotoHash            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  analyses         SkinAnalysis[]
  subscription     Subscription?
  rituals          Ritual[]
  reports          Report[]
  referralsGiven   Referral[]        @relation("Referrer")
  referralsUsed    Referral[]        @relation("Referee")
  chatMessages     ChatMessage[]
  userAchievements UserAchievement[]
  inventory        InventoryItem[]
  routine          Routine?
  bonuses          UserBonus[]
}

model SkinAnalysis {
  id              String   @id @default(cuid())
  userId          String
  photoUrl        String?
  photoBase64     String?
  photoHash       String?
  userDescription String?
  /// Which provider produced this record. "faceplus" is the primary
  /// path; "huggingface" is the fallback we use when Face++ quota is
  /// exhausted (Jun-25 Free Plan outage). Lets ResultModal show a
  /// honest degraded-mode banner when this is "huggingface".
  provider        String   @default("faceplus")
  result          Json?
  /// Verbatim Face++ /skinanalyze response. Lets us re-score old records
  /// when scoring logic improves (avoids paying the Face++ quota again).
  rawFacePlus     Json?
  /// Verbatim HuggingFace Inference API response (YOLO detections) —
  /// populated only for `provider = "huggingface"` records. Stored
  /// separately from rawFacePlus so re-scoring one provider's output
  /// doesn't blow up the other.
  rawHuggingFace  Json?
  /// Verbatim Gemini 2.5 Pro Vision response (responseSchema JSON) —
  /// populated only when Gemini participated in the analysis. Stored
  /// separately so re-scoring Gemini's verdicts doesn't intersect with
  /// Face++ / HuggingFace data.
  rawGemini       Json?
  skinType        String?
  isFree          Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("active")
  type      String   @default("trial")
  startDate DateTime @default(now())
  endDate   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Ritual {
  id               String    @id @default(cuid())
  userId           String    @unique
  lastDate         DateTime  @default(now())
  streak           Int       @default(0)
  maxStreak        Int       @default(0)
  nextAnalysisDate DateTime?
  weeklyStreak     Int       @default(0)
  /// Last streak-milestone value we sent a push notification for.
  /// Prevents same-day re-analyses from re-firing the milestone message.
  /// Null means "nothing sent yet".
  lastSentMilestone Int?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  generatedAt DateTime @default(now())
  dynamics    Json?
  summary     String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([generatedAt])
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  refereeId  String   @unique
  bonusGiven Boolean  @default(false)
  createdAt  DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referee  User @relation("Referee", fields: [refereeId], references: [id])

  @@index([referrerId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   @default("user")
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model InventoryItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  brand       String?
  ingredients String?
  analysis    Json?
  imageUrl    String?
  source      String   @default("manual")
  sourceUrl   String?
  createdAt   DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  routine RoutineStep[]

  @@index([userId])
}

model Routine {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id])
  steps RoutineStep[]
}

model RoutineStep {
  id          String   @id @default(cuid())
  routineId   String
  inventoryId String?
  productName String
  timeOfDay   String   // "morning" | "evening"
  dayOfWeek   Int?     // null = every day, 0=Sun..6=Sat
  stepOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  routine   Routine        @relation(fields: [routineId], references: [id], onDelete: Cascade)
  inventory InventoryItem? @relation(fields: [inventoryId], references: [id])

  @@index([routineId])
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String
  icon        String
  xpReward    Int      @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserBonus {
  id        String    @id @default(cuid())
  userId    String
  kind      String    // free_analysis | chat_questions | streak_freeze | discount_coupon | pro_trial | badge_month_streak
  amount    Int       @default(1)
  remaining Int       @default(1)
  sourceKey String?   // achievement.key, if awarded by one
  code      String?   @unique
  discount  Int?
  appliedTo String?   // tier sku: pack5 | monthly
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, kind])
}

/// Idempotency guard for Telegram Stars webhook. Tracks which invoice
/// payloads have already been credited so webhook retries don't double-credit.
model ProcessedInvoice {
  id          String   @id @default(cuid())
  payload     String   @unique
  userId      String
  kind        String   // "analysis" | "chat"
  amount      Int
  currency    String
  processedAt DateTime @default(now())

  @@index([userId])
  @@index([processedAt])
}

/// Records a user's claim that they transferred money for a card-paid tier.
/// Prevents spam — admin bot sees at most one notification per (user, tier)
/// per cooldown window.
model CardTransferClaim {
  id        String   @id @default(cuid())
  userId    String
  tier      String   // "single" | "pack5" | "monthly"
  amount    Int
  claimedAt DateTime @default(now())

  @@index([userId, tier, claimedAt])
}
