generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(cuid())
  telegramId               String   @unique
  name                     String?
  /// Telegram @username (without `@` prefix), synced silently on every
  /// `auth.me()` and saved on first register. Used by admin as a
  /// matcher for manual card-transfer credits — user puts the same
  /// `@username` in their bank transfer comment so admin can find them
  /// in their bank statement. Nullable (user can hide username from
  /// Telegram privacy settings). Not unique — Telegram may recycle
  /// usernames when accounts are deleted.
  username                 String?
  level                    Int      @default(1)
  xp                       Int      @default(0)
  freeAnalyses             Int      @default(3)
  paidAnalyses             Int      @default(0)
  freeChatQuestions        Int      @default(3)
  referralCount            Int      @default(0)
  streakFreezes            Int      @default(0)
  proTrialUntil            DateTime?
  monthStreakBadge         Boolean  @default(false)
  subscriptionEnd          DateTime?
  lastSubscriptionOfferSent DateTime?
  /// Photo-perceptual hash of the user's most recent analysis. Used for
  /// O(1) duplicate detection before falling back to full hash scan.
  lastPhotoHash            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  analyses         SkinAnalysis[]
  subscription     Subscription?
  rituals          Ritual[]
  reports          Report[]
  referralsGiven   Referral[]        @relation("Referrer")
  referralsUsed    Referral[]        @relation("Referee")
  chatMessages     ChatMessage[]
  userAchievements UserAchievement[]
  inventory        InventoryItem[]
  routine          Routine?
  bonuses          UserBonus[]
  adminGrants      AdminGrant[]
  cardTransferClaims CardTransferClaim[]
  monthlyWins      MonthlyWinner[]

  @@index([username])
}

/// 2026-06-28 — Monthly Top-1 winner ledger. Each row records the
/// system-granted reward for the user who ranked #1 in a given leaderboard
/// category for a given calendar month. UNIQUE on (month, category)
/// guarantees the cron-job.org driver can retry the payout route
/// (`/api/cron/grant-monthly-winner`) without ever double-crediting.
/// `month` is "YYYY-MM" in UTC (server tz). `category` is one of the
/// three leaderboard dimensions — only "referrers" pays out today;
/// the column exists so the same ledger can carry streak/level winners
/// in a future change without migration.
model MonthlyWinner {
  id        String   @id @default(cuid())
  /// "YYYY-MM" UTC (e.g. "2026-06"). Composite UNIQUE with `category`.
  month     String
  category  String   // "referrers" | "streaks" | "level"
  userId    String
  /// Payout value, paid in `paidAnalyses` increments (5 = pack5-equivalent).
  payout    Int
  /// Snapshot of the metric value at award time (e.g. referralCount=12).
  metricValue Int
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([month, category])
  @@index([userId, grantedAt])
}

/// 2026-06-26 — Audit log of admin grants. Every reward, refund, or
/// manual compensation admin applies via the /admin panel (or any
/// future tooling) writes a row here so we can trace "why does this
/// user suddenly have +20 paidAnalyses". `adminTelegramId` is the
/// literal "admin" in MVP (single fixed operator); expand to per-admin
/// id when multi-admin support is added.
model AdminGrant {
  id              String   @id @default(cuid())
  adminTelegramId String
  targetUserId    String
  /// One of: "paidAnalyses" | "freeChatQuestions" | "streakFreeze" |
  /// "subscriptionDays" | "proTrialDays" | "xp". See adminService.grant
  /// for the exhaustive mapping.
  kind            String
  amount          Int
  reason          String?
  /// Snapshot of what changed (e.g. { from: 0, to: 5 } for `paidAnalyses`,
  /// or { until: "...", extendedBy: 30 } for `subscriptionDays`).
  details         Json?
  createdAt       DateTime @default(now())

  target User @relation(fields: [targetUserId], references: [id])

  @@index([targetUserId, createdAt])
  @@index([createdAt])
}

model SkinAnalysis {
  id              String   @id @default(cuid())
  userId          String
  photoUrl        String?
  photoBase64     String?
  photoHash       String?
  userDescription String?
  /// Which provider produced this record. "faceplus" is the primary
  /// path; "huggingface" is the fallback we use when Face++ quota is
  /// exhausted (Jun-25 Free Plan outage). Lets ResultModal show a
  /// honest degraded-mode banner when this is "huggingface".
  provider        String   @default("faceplus")
  result          Json?
  /// Verbatim Face++ /skinanalyze response. Lets us re-score old records
  /// when scoring logic improves (avoids paying the Face++ quota again).
  rawFacePlus     Json?
  /// Verbatim HuggingFace Inference API response (YOLO detections) —
  /// populated only for `provider = "huggingface"` records. Stored
  /// separately from rawFacePlus so re-scoring one provider's output
  /// doesn't blow up the other.
  rawHuggingFace  Json?
  /// Verbatim Gemini 2.5 Pro Vision response (responseSchema JSON) —
  /// populated only when Gemini participated in the analysis. Stored
  /// separately so re-scoring Gemini's verdicts doesn't intersect with
  /// Face++ / HuggingFace data.
  rawGemini       Json?
  skinType        String?
  isFree          Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("active")
  type      String   @default("trial")
  startDate DateTime @default(now())
  endDate   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Ritual {
  id               String    @id @default(cuid())
  userId           String    @unique
  lastDate         DateTime  @default(now())
  streak           Int       @default(0)
  maxStreak        Int       @default(0)
  nextAnalysisDate DateTime?
  weeklyStreak     Int       @default(0)
  /// Last streak-milestone value we sent a push notification for.
  /// Prevents same-day re-analyses from re-firing the milestone message.
  /// Null means "nothing sent yet".
  lastSentMilestone Int?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  generatedAt DateTime @default(now())
  dynamics    Json?
  summary     String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([generatedAt])
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  refereeId  String   @unique
  bonusGiven Boolean  @default(false)
  createdAt  DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referee  User @relation("Referee", fields: [refereeId], references: [id])

  @@index([referrerId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   @default("user")
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model InventoryItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  brand       String?
  ingredients String?
  analysis    Json?
  imageUrl    String?
  source      String   @default("manual")
  sourceUrl   String?
  createdAt   DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  routine RoutineStep[]

  @@index([userId])
}

model Routine {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id])
  steps RoutineStep[]
}

model RoutineStep {
  id          String   @id @default(cuid())
  routineId   String
  inventoryId String?
  productName String
  timeOfDay   String   // "morning" | "evening"
  dayOfWeek   Int?     // null = every day, 0=Sun..6=Sat
  stepOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  routine   Routine        @relation(fields: [routineId], references: [id], onDelete: Cascade)
  inventory InventoryItem? @relation(fields: [inventoryId], references: [id])

  @@index([routineId])
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String
  icon        String
  xpReward    Int      @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserBonus {
  id        String    @id @default(cuid())
  userId    String
  kind      String    // free_analysis | chat_questions | streak_freeze | discount_coupon | pro_trial | badge_month_streak
  amount    Int       @default(1)
  remaining Int       @default(1)
  sourceKey String?   // achievement.key, if awarded by one
  code      String?   @unique
  discount  Int?
  appliedTo String?   // tier sku: pack5 | monthly
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, kind])
}

/// Idempotency guard for Telegram Stars webhook. Tracks which invoice
/// payloads have already been credited so webhook retries don't double-credit.
model ProcessedInvoice {
  id          String   @id @default(cuid())
  payload     String   @unique
  userId      String
  kind        String   // "analysis" | "chat"
  amount      Int
  currency    String
  processedAt DateTime @default(now())

  @@index([userId])
  @@index([processedAt])
}/// Records a user's claim that they transferred money for a card-paid tier.
/// Phase 1 (2026-06-26): added reference tracking (expected/submitted),
/// screenshot upload, and credit-confirmation status. The `expectedReference`
/// is a UNIQUE short code (e.g. "R-A9B2-XR7K") returned to the user and
/// shown in the bank-transfer comment field; admin matches it to incoming
/// payments. UNIQUE prevents accidental double-credit and dedups duplicate
/// "Я оплатил" clicks without needing a time window.
///
/// Phase 1.5 (2026-06-26): added `notificationSentAt` to distinguish
/// "draft" (modal opened, ref issued, no admin notification yet) from
/// "submitted" (user clicked "Я оплатил" — admin was notified). The
/// `previewCardTransfer` mutation creates the draft; `reportCardTransfer`
/// updates it + sends the notification (once, idempotent via this flag).
model CardTransferClaim {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tier                String    // "single" | "pack5" | "fifteen" | "monthly"
  amount              Int
  /// Short auto-generated ref displayed to user + sent in admin notification.
  /// Format: "R-{userLast4Uid}-{random4Hex}" — ≈12 chars, easy to copy,
  /// unique via DB UNIQUE index (catches accidental double-click re-submits).
  /// Phase 1.5: ref is now issued on `previewCardTransfer` (modal open),
  /// BEFORE the user makes their bank transfer, so they can put it in the
  /// transfer comment field.
  expectedReference   String    @unique
  /// User-typed/observed ref from their banking app confirmation. Optional
  /// cross-check; admin scans bank statement for this string to match.
  submittedReference  String?
  /// Optional screenshot of the payment confirmation screen from user's
  /// banking app. Stored as base64 (max ~1MB enforced client-side). Short
  /// Phase 1 hack — Phase 2 (Smart Global Payment) makes this obsolete.
  screenshotBase64    String?
  /// Flagged true after admin has matched the ref in their bank statement
  /// AND credited the user. Drives both the push notification to user and
  /// the `scripts/credit-by-ref.ts` admin tooling's idempotency.
  creditConfirmed     Boolean   @default(false)
  creditConfirmedAt   DateTime?
  /// Phase 1.5 — when telegram notification to admin bot was dispatched
  /// (null = draft from preview, set = user clicked "Я оплатил").
  /// null ↔ draft from preview (may or may not be confirmed later);
  /// set ↔ admin was already notified about this claim.
  /// Drives both idempotent re-clicks AND admin notification dedup.
  notificationSentAt  DateTime?

  claimedAt           DateTime  @default(now())

  @@index([userId, tier, claimedAt])
  @@index([creditConfirmed, claimedAt])
  @@index([userId, tier, notificationSentAt])
}
